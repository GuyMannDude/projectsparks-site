{  
  "hosting": {  
    "public": ".",  
    "cleanUrls": true,  
    "ignore": [  
      "firebase.json",  
      "**/.*",  
      "**/node_modules/**"  
    ],  
    "headers": [  
      {  
        "source": "**",  
        "headers": [  
          {  
            "key": "Cache-Control",  
            "value": "max-age=0"  
          }  
        ]  
      }  
    ]  
  }  
}  
